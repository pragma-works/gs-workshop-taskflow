{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.unit.config.ts"
  },
  "checkers": [
    "typescript"
  ],
  "coverageAnalysis": "off",
  "concurrency": 2,
  "mutate": [
    "src/services/**/*.ts",
    "!src/services/**/*.unit.test.ts"
  ],
  "allowEmpty": true
}