{
  "testRunner": "vitest",
  "vitest": { "configFile": "vitest.config.ts" },
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/__tests__/**",
    "!src/server.ts",
    "!src/db.ts"
  ],
  "reporters": ["clear-text", "html"],
  "htmlReporter": { "fileName": "reports/mutation/mutation-report.html" },
  "coverageAnalysis": "perTest",
  "concurrency": 2,
  "timeoutMS": 30000
}
